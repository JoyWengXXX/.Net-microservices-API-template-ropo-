{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Tasks": [
    {
      "TaskName": "LogInTokenClearTask",
      "TimeOfDay": "00:00",
      "Interval": {
        "Days": 30
      }
    },
    {
      "TaskName": "StoreClearTask",
      "TimeOfDay": "00:00",
      "Interval": {
        "Days": 5
      }
    },
    {
      "TaskName": "PcbDisableTask",
      "Interval": {
        "Hours": 1
      }
    },
    {
      "TaskName": "PcbRegistryApplyClearTask",
      "Interval": {
        "Minutes": 30
      }
    },
    {
      "TaskName": "KeepAliveAsyncTask",
      "Interval": {
        "Minutes": 5
      }
    },
    {
      "TaskName": "DbConnectionMonitorAsyncTask",
      "Interval": {
        "Seconds": 30
      }
    },
    {
      "TaskName": "DailyRecordSettlementTask",
      "TimeOfDay": "XX:00",
      "Interval": {
        "Hours": 1
      }
    },
    {
      "TaskName": "HourlyRecordPersistenceTask",
      "TimeOfDay": "XX:00",
      "Interval": {
        "Hours": 1
      }
    },
    {
      "TaskName": "DailyAccountingAggregationTask",
      "TimeOfDay": "XX:10",
      "Interval": {
        "Hours": 1
      }
    }
  ],
  "EnvironmentSettings": [
    {
      "EnvironmentName": "__ENVIRONMENT__",
      "DiscordWebHookUrl": "__PLACEHOLDER__",
      "ConnectionWarningThreshold": 0.8
    }
  ]
}