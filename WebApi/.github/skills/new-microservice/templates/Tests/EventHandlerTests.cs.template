            _mockRepo.Setup(x => x.UpdateAsync(
                It.IsAny<Expression<Func<{{EntityName}}, bool>>>(),
                It.IsAny<Expression<Func<{{EntityName}}, bool>>>(),
                It.IsAny<IUnitOfWork>()))
                .Returns(Task.FromResult(1));

            // Act
            await _sut.On(@event);

            // Assert
            _mockRepo.Verify(x => x.UpdateAsync(
                It.IsAny<Expression<Func<{{EntityName}}, bool>>>(),
                It.IsAny<Expression<Func<{{EntityName}}, bool>>>(),
                It.IsAny<IUnitOfWork>()),
                Times.Once);
        }

        // ── Disable ──────────────────────────────────────────────────────────

        [Fact]
        public async Task On_Disable{{EntityName}}Event_ReturnsTResultWithSuccess()
        {
            // Arrange
            var @event = new Disable{{EntityName}}Event
