                .ReturnsAsync(mocked{{EntityName}});
            _mockRepo.Setup(x => x.UpdateAsync(
                It.IsAny<Expression<Func<{{EntityName}}, bool>>>(),
                It.IsAny<Expression<Func<{{EntityName}}, bool>>>(),
